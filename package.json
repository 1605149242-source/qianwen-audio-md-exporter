{
  "name": "qianwen-audio-md-exporter",
  "version": "0.1.0",
  "private": true,
  "description": "Local CLI automation for uploading audio to Qianwen/Tingwu and exporting Markdown transcripts.",
  "type": "module",
  "bin": {
    "qianwen-audio-md-exporter": "./src/cli.js"
  },
  "scripts": {
    "start": "node ./src/cli.js",
    "web": "node ./src/web.js --open",
    "check": "node ./tests/smoke.js",
    "build:exe": "pkg . --targets node22-win-x64 --output dist/qianwen-audio-md-exporter.exe"
  },
  "dependencies": {
    "playwright-core": "^1.56.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.6.0"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js",
      "src/**/*.py"
    ],
    "assets": [
      "README.md",
      "docs/**/*.md",
      "node_modules/playwright-core/browsers.json"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
